# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=AI Business Creator
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_DB=ai_business_creator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:changeme_in_production@postgres:5432/ai_business_creator

# ── Backend ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

# ── Frontend ───────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NAME=AI Business Creator

